{
  "name": "abrasio-sdk",
  "version": "0.2.1",
  "description": "Node.js SDK for Abrasio - Stealth web scraping with Patchright (local + cloud)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "dev": "tsc --watch",
    "example:basic": "tsx examples/basic.ts",
    "example:cloud": "tsx examples/cloud.ts",
    "example:human": "tsx examples/human-behavior.ts",
    "release": "bash scripts/release.sh"
  },
  "keywords": [
    "scraping",
    "patchright",
    "stealth",
    "chromium",
    "automation",
    "abrasio",
    "anti-detection",
    "web-scraping"
  ],
  "author": "João Sobhie",
  "license": "MIT",
  "dependencies": {
    "patchright": "^1.49.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
